{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "478020856831942788"
    }
  },
  "parameters": {
    "purviewAccountName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63,
      "metadata": {
        "description": "Name of the Purview account. Must be globally unique within the tenant."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the Purview account."
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Free",
        "Standard"
      ],
      "metadata": {
        "description": "Purview SKU. Free is intended only for short-lived evaluations."
      }
    },
    "skuCapacity": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "metadata": {
        "description": "SKU capacity (vCores). Standard minimum is 1."
      }
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Disabled",
      "allowedValues": [
        "Enabled",
        "Disabled"
      ],
      "metadata": {
        "description": "Public network access to the Purview account. Defaults to Disabled per the secure-by-design rule in .github/instructions/security.instructions.md. Reference: https://learn.microsoft.com/en-us/purview/data-gov-classic-security-best-practices#deploy-private-endpoints-for-microsoft-purview-accounts"
      }
    },
    "managedResourceGroupName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Managed resource group name. Leave empty to let Azure auto-generate."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "workload": "purview-as-code",
        "environment": "lab",
        "owner": "contoso-lab"
      },
      "metadata": {
        "description": "Resource tags."
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the lab automation Key Vault from `infra/parameters/lab.yaml` (`resources.keyVault.name`). Consumed by `modules/role-definitions.bicep` so the `Purview-Lab-KV-Firewall-Toggler` custom role is assignable only at the vault resource scope. The vault itself is provisioned by `scripts/New-AutomationKeyVault.ps1` (Wave 0 #5a), not from this template; this parameter only resolves an `existing` reference."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Purview/accounts",
      "apiVersion": "2024-04-01-preview",
      "name": "[parameters('purviewAccountName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "[parameters('skuName')]",
        "capacity": "[parameters('skuCapacity')]"
      },
      "properties": {
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "managedResourceGroupName": "[if(empty(parameters('managedResourceGroupName')), null(), parameters('managedResourceGroupName'))]",
        "managedEventHubState": "Enabled"
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "role-definitions",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "keyVaultName": {
            "value": "[parameters('keyVaultName')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "3127994151465139573"
            }
          },
          "parameters": {
            "keyVaultName": {
              "type": "string",
              "metadata": {
                "description": "Name of the lab automation Key Vault from `infra/parameters/lab.yaml` (`resources.keyVault.name`). Resolved as an existing resource so the custom role is assignable only at the vault resource scope."
              }
            }
          },
          "variables": {
            "kvFirewallTogglerRoleName": "[guid(subscription().id, 'Purview-Lab-KV-Firewall-Toggler')]"
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleDefinitions",
              "apiVersion": "2022-04-01",
              "name": "[variables('kvFirewallTogglerRoleName')]",
              "properties": {
                "roleName": "Purview-Lab-KV-Firewall-Toggler",
                "description": "PR D1a / Issue #256 — least-privilege custom role granting only Microsoft.KeyVault/vaults/write, assignable to the lab automation Key Vault. Used by the kv-temp-unlock workflow identity to toggle publicNetworkAccess on/off.",
                "type": "CustomRole",
                "permissions": [
                  {
                    "actions": [
                      "Microsoft.KeyVault/vaults/write"
                    ],
                    "notActions": [],
                    "dataActions": [],
                    "notDataActions": []
                  }
                ],
                "assignableScopes": [
                  "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
                ]
              }
            }
          ],
          "outputs": {
            "kvFirewallTogglerRoleId": {
              "type": "string",
              "metadata": {
                "description": "Full resource ID of the `Purview-Lab-KV-Firewall-Toggler` custom role definition. Consumed by `infra/modules/kv-unlock-rbac.bicep` (PR D1b) once the kv-unlock SP object ID is known."
              },
              "value": "[resourceId('Microsoft.Authorization/roleDefinitions', variables('kvFirewallTogglerRoleName'))]"
            },
            "kvFirewallTogglerRoleGuid": {
              "type": "string",
              "metadata": {
                "description": "Role-definition GUID (the `name` segment of the resource ID). Convenience output for scripts that pass `--role` by ID rather than name."
              },
              "value": "[variables('kvFirewallTogglerRoleName')]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "purviewAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Purview/accounts', parameters('purviewAccountName'))]"
    },
    "purviewAccountName": {
      "type": "string",
      "value": "[parameters('purviewAccountName')]"
    },
    "purviewAtlasEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.purview.azure.com', parameters('purviewAccountName'))]"
    },
    "systemAssignedPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Purview/accounts', parameters('purviewAccountName')), '2024-04-01-preview', 'full').identity.principalId]"
    },
    "kvFirewallTogglerRoleId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the `Purview-Lab-KV-Firewall-Toggler` custom role definition. Consumed by PR D1b's `scripts/New-KvUnlockRbac.ps1`."
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'role-definitions'), '2025-04-01').outputs.kvFirewallTogglerRoleId.value]"
    }
  }
}