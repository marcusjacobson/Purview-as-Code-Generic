{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://purview-as-code.contoso-lab/critical-data-elements.schema.json",
    "title": "Microsoft Purview Unified Catalog — critical data elements",
    "description": "Desired state for Unified Catalog critical data elements consumed by scripts/Deploy-UnifiedCatalog.ps1 (tracked in #340). Reference: https://learn.microsoft.com/en-us/purview/unified-catalog. Per ADR 0024, Microsoft Learn does not yet document the Unified Catalog REST data-plane surface; the field shape below will be tightened when the authoring-surface ADR lands.",
    "type": "object",
    "additionalProperties": false,
    "required": [ "items" ],
    "properties": {
        "items": {
            "type": "array",
            "items": { "$ref": "#/definitions/criticalDataElement" },
            "description": "List of critical data elements. Default state is the empty list."
        }
    },
    "definitions": {
        "criticalDataElement": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "name", "domain" ],
            "properties": {
                "name":        { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "domain":      { "type": "string", "minLength": 1 },
                "dataType": {
                    "type": "string",
                    "enum": [ "String", "Number", "Date", "Boolean", "Identifier", "Other" ]
                },
                "owners": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                },
                "status": {
                    "type": "string",
                    "enum": [ "Draft", "Published", "Expired" ]
                }
            }
        }
    }
}
