{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://purview-as-code.contoso-lab/data-products.schema.json",
    "title": "Microsoft Purview Unified Catalog — data products",
    "description": "Desired state for Unified Catalog data products consumed by scripts/Deploy-UnifiedCatalog.ps1 (tracked in #340). Reference: https://learn.microsoft.com/en-us/purview/unified-catalog. Per ADR 0024, Microsoft Learn does not yet document the Unified Catalog REST data-plane surface; the field shape below will be tightened when the authoring-surface ADR lands.",
    "type": "object",
    "additionalProperties": false,
    "required": [ "items" ],
    "properties": {
        "items": {
            "type": "array",
            "items": { "$ref": "#/definitions/dataProduct" },
            "description": "List of data products. Default state is the empty list."
        }
    },
    "definitions": {
        "dataProduct": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "name", "domain" ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Display name. Unique across the file."
                },
                "description": {
                    "type": "string"
                },
                "domain": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Parent business domain name. Must match an entry in business-domains.yaml."
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "Dataset",
                        "Dashboard",
                        "MLModel",
                        "Operational",
                        "MasterData",
                        "Reference",
                        "Other",
                        "Master",
                        "Analytical",
                        "AI",
                        "MasterDataAndReferenceData",
                        "BusinessSystemOrApplication",
                        "ModelTypes",
                        "DashboardsOrReports",
                        "MLAITrainingDataSet",
                        "MLAITestingDataSet",
                        "TransactionalDataset",
                        "AnalyticsModel",
                        "SemanticModel"
                    ]
                },
                "businessUse": {
                    "type": "string"
                },
                "owners": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                },
                "status": {
                    "type": "string",
                    "enum": [ "Draft", "Published", "Expired" ]
                }
            }
        }
    }
}
